\RequirePackage{parskip}           % Space between paragraphs, no indent
\RequirePackage{setspace}          % Line spacing control
\setstretch{1.15}                  % Slightly open line spacing for readability
\RequirePackage{xspace}            % Smart spacing after macros
\RequirePackage{marginnote}        % Margin annotations
\RequirePackage{mdframed}          % Additional framed boxes if needed
\RequirePackage{etoolbox}          % General programming tools

%% ============================================================
%% §19  CUSTOM MACROS & SHORTHAND
%% ============================================================

%% Styled brand name
\newcommand{\PrepFusion}{\textbf{\textcolor{pfBlue}{PrepFusion}}\xspace}

%% Portal names
\newcommand{\COAP}{\textsc{coap}\xspace}
\newcommand{\CCMT}{\textsc{ccmt}\xspace}
\newcommand{\GATE}{\textsc{gate}\xspace}
\newcommand{\PGEE}{\textsc{pgee}\xspace}

%% Score / rank formatting
\newcommand{\score}[1]{\textbf{\textcolor{pfGreen}{#1}}}
\newcommand{\rank}[1]{\textbf{\textcolor{pfBlue}{Rank #1}}}
\newcommand{\cutoff}[1]{\textbf{\textcolor{pfOrange}{#1+}}}

%% Section divider rule
\newcommand{\sectionrule}{%
  \vspace{4pt}%
  {\color{pfOrange}\rule{\linewidth}{0.8pt}}%
  \vspace{4pt}%
}

%% Institute name emphasis
\newcommand{\inst}[1]{\textbf{\textcolor{pfBlue}{#1}}}

%% Margin tip shortcut
\newcommand{\margintip}[1]{%
  \marginnote{\tiny\sffamily\color{pfDarkGrey}#1}
}

